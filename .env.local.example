# Client-side Firebase config (safe to expose, gated by Firebase security rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side only — not prefixed with NEXT_PUBLIC_, never exposed to browser
# Full service account JSON as a single-line string
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# Comma-separated emails that will be granted freevite:organizer custom claim on first sign-in
ORGANIZER_EMAILS=you@example.com

# Resend API key — sender domain must be verified in Resend dashboard
RESEND_API_KEY=

# Full app URL used to construct magic links in invite emails
APP_URL=https://free-vite.com
